# MiniMax API 配置（必填）
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7
LLM_TEMPERATURE=0.8

# Redis
REDIS_URL=redis://localhost:6379
# Docker Compose 环境：
# REDIS_URL=redis://redis:6379

# 安全 — 允许的 CORS 前端域名（必填，多个用逗号分隔）
# 示例：http://localhost:3000,https://empathic-bot.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# 前端必读：VITE_GATEWAY_URL 请在 Vercel 环境变量中设置为你的 Railway Gateway 地址
# 例如：https://empathic-bot.up.railway.app

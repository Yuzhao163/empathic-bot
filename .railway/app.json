{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd python_service && pip install -e .",
    "startCommand": "cd gateway && go run main.go"
  },
  "environments": {
    "web": {
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd frontend && npm install && npm run build"
      },
      "staticFiles": {
        "root": "./dist",
        "wildcard": true
      }
    }
  }
}

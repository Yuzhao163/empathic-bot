# ============================================================
# 生产环境变量 — 复制为 .env.production 并填入真实值
# ============================================================

# 必填
MINIMAX_API_KEY=sk-xxxxyour-minimax-api-key
ALLOWED_ORIGINS=https://empathic-bot.vercel.app,https://empathic-bot-yourname.vercel.app

# Redis（Railway 插件自动注入，通常不需要修改）
REDIS_URL=redis://redis:6379

# Go Gateway
GATEWAY_LOG_LEVEL=info
PORT=8080

# Python LLM
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=1000
MAX_CONTEXT_TOKENS=6000

# 前端（部署到 Vercel 时在 Vercel Dashboard 设置）
# VITE_GATEWAY_URL=https://your-railway-app.up.railway.app
